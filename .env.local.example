# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini (https://aistudio.google.com) — server only, free tier
GEMINI_API_KEY=
# 단일 모델 (PDF 가져오기 등에서 사용)
GEMINI_MODEL=gemini-2.5-flash
# 채팅 모델 폴백 순서 (쉼표 구분). 앞 모델이 한도(429)/사용 불가(404)면 다음 모델로 자동 전환.
# 미설정 시 기본값: gemini-3-flash-preview,gemini-3.5-flash,gemini-2.5-flash
GEMINI_MODELS=gemini-3-flash-preview,gemini-3.5-flash,gemini-2.5-flash

# Upstash Redis (https://upstash.com) — rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Kakao Share SDK
NEXT_PUBLIC_KAKAO_JS_KEY=

# Site URL (used for OG tags, redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin: set app_metadata.role = "admin" in Supabase Auth (see README)

# Sentry (optional)
SENTRY_DSN=

# E2E integration (optional — npm run test:e2e:integration)
# Supabase Auth에서 이메일 확인 비활성화된 전용 테스트 계정 권장
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
# 기존 슬러그 재사용 시 (미설정 시 온보딩에서 새 슬러그 생성)
E2E_TEST_SLUG=
