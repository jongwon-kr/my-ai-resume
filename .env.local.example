# CloneCV local environment — copy to .env.local

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini (AI Studio)
GEMINI_API_KEY=

# Upstash Redis (rate limits — required in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Kakao share (optional)
NEXT_PUBLIC_KAKAO_JS_KEY=

# Inquiry email via Resend (optional)
RESEND_API_KEY=
INQUIRY_FROM_EMAIL=

# Sentry (optional — recommended for production)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# E2E integration tests (optional)
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
E2E_TEST_SLUG=

# Playwright
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# PLAYWRIGHT_SKIP_WEBSERVER=1
